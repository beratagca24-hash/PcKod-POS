<Window x:Class="PcKod.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PcKod POS - Öz Biga Et" Height="750" Width="1150" 
        WindowStartupLocation="CenterScreen" Background="#121212">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <GroupBox Header="GÜNCEL SATIŞ SEPETİ" Foreground="#00FF41" BorderBrush="#333" Margin="5">
            <DataGrid Name="dgSepet" Background="#1E1E1E" Foreground="White" RowBackground="#1E1E1E"
                      AutoGenerateColumns="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#333" BorderThickness="0" FontSize="18" FontWeight="SemiBold">
                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#252525"/>
                        <Setter Property="Foreground" Value="#00FF41"/>
                        <Setter Property="Padding" Value="10,5"/>
                    </Style>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="5"/>
                    </Style>
                </DataGrid.Resources>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Ürün Adı" Binding="{Binding UrunAdi}" Width="2*"/>
                    <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar}" Width="*"/>
                    <DataGridTextColumn Header="Birim" Binding="{Binding BirimMetni}" Width="0.5*"/>
                    <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyat, StringFormat=C2}" Width="*"/>
                    <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamTutar, StringFormat=C2}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Grid Grid.Column="1" Margin="10,5,10,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button Name="btnSifreDegistir" Grid.Row="0" Content="⚙️ AYARLAR" Width="100" Height="30" 
                    HorizontalAlignment="Right" Background="#333" Foreground="#A0A0A0" 
                    BorderThickness="1" BorderBrush="#444" Click="btnSifreDegistir_Click" Margin="0,0,0,10"/>

            <StackPanel Grid.Row="1">
                <Border Background="#1E1E1E" CornerRadius="10" Padding="15" Margin="0,0,0,15" BorderBrush="#00FF41" BorderThickness="1">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="GENEL TOPLAM" Foreground="#A0A0A0" FontSize="14" HorizontalAlignment="Center"/>
                        <TextBlock Name="txtGenelToplam" Text="₺0,00" Foreground="#00FF41" FontSize="48" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <TextBox Name="txtBarkodOkuyucu" Background="#252525" Foreground="White" BorderBrush="#00FF41" Padding="12" FontSize="22" KeyDown="txtBarkodOkuyucu_KeyDown" Margin="0,0,0,20"/>

                <Grid Margin="0,0,0,15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Name="btnNakit" Grid.Column="0" Height="80" Background="#28A745" Click="btnNakit_Click">
                        <StackPanel>
                            <TextBlock Text="💵 NAKİT" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="(Satışı Bitir)" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Name="btnKart" Grid.Column="2" Height="80" Background="#2980B9" Click="btnKart_Click">
                        <StackPanel>
                            <TextBlock Text="💳 KART" Foreground="White" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="(Satışı Bitir)" Foreground="White" FontSize="10" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Button Name="btnRaporHazirlik" Content="📊 GÜNLÜK EXCEL RAPORU" Height="50" Background="#F39C12" Foreground="White" FontWeight="Bold" Click="btnRaporHazirlik_Click" Margin="0,0,0,20"/>
                <StackPanel Name="pnlRaporSifre" Visibility="Collapsed" Margin="0,-15,0,20">
                    <PasswordBox Name="txtRaporSifre" Background="#252525" Foreground="White" BorderBrush="#F39C12" Padding="8" KeyDown="txtRaporSifre_KeyDown"/>
                    <Grid Margin="0,5,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Onayla" Background="#E67E22" Foreground="White" Margin="0,0,2,0" Click="btnRaporOnay_Click"/>
                        <Button Content="Vazgeç" Background="#7F8C8D" Foreground="White" Margin="2,0,0,0" Click="btnRaporIptal_Click"/>
                    </Grid>
                </StackPanel>

                <Button Content="📦 Ürün Yönetimi" Height="45" Margin="0,0,0,10" Background="#333" Foreground="White" Click="btnUrunListesi_Click"/>
                <Button Content="🏢 Yeni Firma Kaydı" Height="45" Margin="0,0,0,10" Background="#34495E" Foreground="White" Click="btnFirmaEkle_Click"/>
                <Button Content="🚚 TOPTAN SATIŞ MODU" Height="55" Margin="0,0,0,15" Background="#D35400" Foreground="White" FontWeight="Bold" Click="btnToptanSatis_Click"/>
                <Button Content="❌ Sepeti İptal Et" Height="40" Background="#C0392B" Foreground="White" Click="btnSepetiTemizle_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>