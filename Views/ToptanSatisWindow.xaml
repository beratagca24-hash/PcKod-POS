<Window x:Class="PcKod.UI.Views.ToptanSatisWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Toptan Satış Paneli - PcKod" Height="570" Width="1100" 
        Background="#121212" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Content="⬅ ANA SAYFAYA DÖN" HorizontalAlignment="Left" 
                Background="Transparent" Foreground="#666" BorderThickness="0" 
                FontSize="12" Click="btnGeri_Click" Cursor="Hand" Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                <TextBlock Text="Müşteri / Firma Seçin:" Foreground="#A0A0A0" Margin="0,0,0,5"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox Name="cmbFirmalar" Grid.Column="0" DisplayMemberPath="FirmaAdi" SelectedValuePath="Id" 
                              Background="White" Foreground="Black" FontSize="16" Height="35" Margin="0,0,10,0">
                        <ComboBox.ItemContainerStyle>
                            <Style TargetType="ComboBoxItem">
                                <Setter Property="Foreground" Value="Black"/>
                                <Setter Property="Background" Value="White"/>
                            </Style>
                        </ComboBox.ItemContainerStyle>
                    </ComboBox>

                    <Button Name="btnFirmaEkle" Grid.Column="1" Content="➕ Yeni Firma" Background="#34495E" 
                            Foreground="White" FontWeight="Bold" Padding="15,0" Cursor="Hand" Click="btnFirmaEkle_Click"/>
                </Grid>

                <TextBlock Text="Ürün Adı Yazın (Hızlı Arama):" Foreground="#00FF41" Margin="0,0,0,5" FontWeight="Bold"/>
                <TextBox Name="txtUrunAra" Background="#252525" Foreground="White" BorderBrush="#00FF41" 
                         Padding="10" FontSize="18" TextChanged="txtUrunAra_TextChanged" CaretBrush="White"/>

                <ListBox Name="lstAramaSonuclari" Height="120" Background="#1E1E1E" Foreground="White" 
                         BorderBrush="#333" Visibility="Collapsed" MouseDoubleClick="lstAramaSonuclari_MouseDoubleClick">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="300"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding UrunAdi}" Foreground="White" FontWeight="Bold" Grid.Column="0"/>
                                <TextBlock Text="{Binding SatisFiyati, StringFormat='₺\{0:N2\}'}" Foreground="#00FF41" Grid.Column="1"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Toptan Satış Sepeti" Foreground="#A0A0A0" Margin="0,20,0,5"/>

                <DataGrid Name="dgToptanSepet" Height="300" Background="#1E1E1E" Foreground="White" 
                          RowBackground="#1E1E1E" AlternatingRowBackground="#252525" CellEditEnding="dgToptanSepet_CellEditEnding"
                          AutoGenerateColumns="False" CanUserAddRows="False" BorderThickness="0" FontSize="16">
                    <DataGrid.Resources>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#252525"/>
                            <Setter Property="Foreground" Value="#00FF41"/>
                            <Setter Property="Padding" Value="10,5"/>
                        </Style>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="White"/>
                            <Setter Property="Padding" Value="5"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ürün Adı" Binding="{Binding UrunAdi}" IsReadOnly="True" Width="2*"/>
                        <DataGridTextColumn Header="Miktar" Binding="{Binding Miktar, UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Birim Fiyat" Binding="{Binding BirimFiyat, StringFormat='₺\{0:N2\}', UpdateSourceTrigger=PropertyChanged}" Width="*"/>
                        <DataGridTextColumn Header="Toplam" Binding="{Binding ToplamTutar, StringFormat='₺\{0:N2\}'}" IsReadOnly="True" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="10" Padding="20" BorderBrush="#333" BorderThickness="1">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TOPTAN TOPLAM" Foreground="#A0A0A0" HorizontalAlignment="Center" FontSize="14"/>
                    <TextBlock Name="txtToptanToplam" Text="₺0,00" Foreground="#00FF41" FontSize="42" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,15"/>

                    <Button Name="btnToptanBitir" Content="💾 BORCA YAZ" Background="#28A745" Foreground="White" 
                            Height="80" FontSize="20" FontWeight="Bold" BorderThickness="0" Click="btnToptanBitir_Click" Cursor="Hand"/>

                    <TextBlock Text="* Seçili firmanın borcuna eklenecek ve stoktan düşülecektir." 
                               Foreground="#555" FontSize="11" Margin="0,20,0,0" TextAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>